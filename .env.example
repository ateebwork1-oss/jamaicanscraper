SCRAPER_SHARED_SECRET=change_this_to_a_long_random_string_used_as_an_api_key

# --- Search providers ---
# You only need ONE of these. Whichever one you manage to sign up for, set it.
# The code tries them in the order listed and picks the first that returns URLs.

# Serper.dev - 2,500 free queries on signup, no credit card.
# https://serper.dev
SERPER_API_KEY=

# SerpApi - 100 free queries/month, no credit card.
# https://serpapi.com/users/sign_up
SERPAPI_KEY=

# ScrapingDog - 1,000 free credits, no credit card.
# https://www.scrapingdog.com
SCRAPINGDOG_API_KEY=

# Google Custom Search API - 100 queries/day free.
# https://programmablesearchengine.google.com + https://console.cloud.google.com
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
