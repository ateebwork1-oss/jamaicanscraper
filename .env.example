SCRAPER_SHARED_SECRET=change_this_to_a_long_random_string_used_as_an_api_key

# --- Search providers (set at least one; Serper is recommended) ---

# Serper.dev - Google SERP API, 2500 free queries on signup, no credit card.
# Sign up at https://serper.dev and copy your API key from the dashboard.
SERPER_API_KEY=

# Google Custom Search API (optional fallback) - 100 queries/day free.
# https://programmablesearchengine.google.com + https://console.cloud.google.com
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
